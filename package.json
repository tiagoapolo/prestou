{
  "name": "prestou",
  "version": "0.1.0",
  "private": true,
  "description": "Prestou — MVP de cobrança via Pix para prestadores de serviço informais",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "npm run start --workspace @prestou/api",
    "build": "npm run build --workspace @prestou/api && npm run build --workspace @prestou/web",
    "build:pix": "npm run build --workspace @prestou/pix",
    "test:pix": "npm run test --workspace @prestou/pix",
    "dev:api": "npm run dev --workspace @prestou/api",
    "dev:web": "npm run dev --workspace @prestou/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
