{
  "name": "prestou",
  "version": "0.1.0",
  "private": true,
  "description": "Prestou — MVP de cobrança via Pix para prestadores de serviço informais",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "start": "pnpm --filter @prestou/api start",
    "start:web": "pnpm --filter @prestou/web start",
    "railway:build": "node scripts/railway-service.mjs build",
    "railway:start": "node scripts/railway-service.mjs start",
    "build": "pnpm -r --if-present build",
    "build:pix": "pnpm --filter @prestou/pix build",
    "test:pix": "pnpm --filter @prestou/pix test",
    "dev:api": "pnpm --filter @prestou/api dev",
    "dev:web": "pnpm --filter @prestou/web dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=11.9.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
