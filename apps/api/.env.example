# Porta do servidor Fastify
PORT=3333

# URL pública do site, usada nos links enviados ao cliente.
PUBLIC_WEB_URL=http://localhost:3000

# PostgreSQL do Supabase via Transaction Pooler (porta 6543).
# Obrigatória em desenvolvimento, testes e produção.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=5
DATABASE_SSL=true

# Origens permitidas no CORS (separadas por vírgula).
CORS_ORIGINS=http://localhost:3000

# --- Supabase Auth + Storage ---
SUPABASE_URL=https://PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...) ou anon key legada.
SUPABASE_ANON_KEY=sb_publishable_...
# Secret key (sb_secret_...) ou service_role legada. Somente no backend.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_RECEIPTS_BUCKET=receipts
SIGNED_URL_TTL_SECONDS=300

# Protege POST /api/internal/run-reminders chamado pelo cron Railway.
CRON_SECRET=

# --- Notificações ao prestador via WhatsApp ---
# WHATSAPP_MODE: "log" (default, grava a notificação no banco e no log, sem enviar)
#               | "cloud-api" (envia de verdade via Cloud API da Meta)
WHATSAPP_MODE=log

# Só necessários quando WHATSAPP_MODE=cloud-api (ver ARCHITECTURE.md, seção WhatsApp):
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_LANG=pt_BR

# --- Testes integrados (use um projeto Supabase separado e descartável) ---
# O runner ignora os testes da API quando estas variáveis não estão presentes.
TEST_DATABASE_URL=
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=
TEST_SUPABASE_SERVICE_ROLE_KEY=
