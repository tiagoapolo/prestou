# Porta do servidor Fastify
PORT=3333

# URL pública base usada para montar os links de pagamento (página do cliente).
# Em produção, o domínio do web app. Em dev, o Next.js roda em 3000.
PUBLIC_WEB_URL=http://localhost:3000

# Produção (Railway): PostgreSQL do Supabase via Transaction Pooler.
# Ex.: postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_SSL=true

# Desenvolvimento/testes sem DATABASE_URL: SQLite e uploads locais.
DATABASE_PATH=./data/prestou.db
UPLOADS_DIR=./data/uploads

# Origens permitidas no CORS (separadas por vírgula).
CORS_ORIGINS=http://localhost:3000

# --- Supabase Auth + Storage ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Segredo exclusivo da API Railway; nunca usar na PWA.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RECEIPTS_BUCKET=receipts
SIGNED_URL_TTL_SECONDS=300

# Protege POST /api/internal/run-reminders chamado pelo cron Railway.
CRON_SECRET=

# --- Notificações ao prestador via WhatsApp ---
# WHATSAPP_MODE: "log" (default, grava a notificação no banco e no log, sem enviar)
#               | "cloud-api" (envia de verdade via Cloud API da Meta)
WHATSAPP_MODE=log

# Só necessários quando WHATSAPP_MODE=cloud-api (ver ARCHITECTURE.md, seção WhatsApp):
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_LANG=pt_BR
