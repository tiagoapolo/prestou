{
  "name": "@prestou/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local --import tsx --watch src/server.ts",
    "start": "node --env-file-if-exists=.env.local dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^10.1.0",
    "@prestou/pix": "workspace:*",
    "@supabase/supabase-js": "^2.110.7",
    "fastify": "^5.1.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.5",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
  }
}
